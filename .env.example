TELEGRAM_TOKEN=your_bot_token_here
ADMIN_IDS=123456789
# UID/GID владельца папки data на Docker-хосте (Linux: id -u / id -g)
BOT_UID=1000
BOT_GID=1000
# Set automatically by ./deploy.sh from the VERSION file after git pull.
# Do not pin manually unless you want to freeze on an old release.
BOT_IMAGE_TAG=1.0.3
SPREADSHEET_ID=1l-FSeC1mfIXqX-bvoKdfRV5txF0TDQ5aD-8GD8Ey-sw
SHEET_GID=684739217
# Old xls registry mirrored by the bot (empty = disable).
# Must be a native Google Sheet — uploaded .xls/.xlsx cannot be written via API.
SPREADSHEET_MIRROR_ID=
SHEET_MIRROR_GID=
GOOGLE_CREDENTIALS_PATH=credentials.json

# Polling interval (minutes)
POLL_INTERVAL_MINUTES=60

# Reminder hours (24h, comma-separated, weekdays only)
REMINDER_HOURS=10,13,16,18

# Timezone for reminders
TIMEZONE=Europe/Moscow

# Cache: queries use cached data (seconds). Force refresh via 🔄 button.
CACHE_TTL_SECONDS=300
FORCE_REFRESH_COOLDOWN=10

# Notify owners about images pending transfer longer than this many days
SLA_PENDING_DAYS=3
